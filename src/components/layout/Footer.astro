---
import { SITE } from "../../data/site-config";
import { footerNav } from "../../data/nav";
---

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Top row: brand + columns -->
    <nav aria-label="Footer navigation">
    <div class="lg:grid lg:grid-cols-6 gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-2 mb-10 lg:mb-0">
        <a href="/" class="inline-flex items-center gap-2.5">
          <svg class="h-7 w-7" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="#0D9488"/>
            <text x="16" y="23" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="20" fill="white">D</text>
          </svg>
          <span class="font-bold text-gray-900 dark:text-white">Arabia Expat</span>
        </a>
        <p class="mt-3 text-sm text-gray-500 dark:text-gray-400 max-w-xs leading-relaxed">
          Your complete guide to living in the Gulf. Visas, daily life, housing, healthcare, and relocation resources for expats in the UAE, Qatar, and Saudi Arabia.
        </p>
        <div class="mt-3 text-xs text-gray-400 dark:text-gray-500">
          Based on official {SITE.year} data.
        </div>
        <div class="mt-3">
          <a href="mailto:contact@arabiaexpat.com" class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">contact@arabiaexpat.com</a>
        </div>
      </div>

      <!-- Link columns -->
      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Country Guides</h3>
        <ul class="space-y-2.5">
          {footerNav.countries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Expat Guides</h3>
        <ul class="space-y-2.5">
          {footerNav.guides.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-2.5">
          {footerNav.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4 mt-6">Sister Sites</h3>
        <ul class="space-y-2.5">
          {footerNav.sisterSites.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors" target="_blank" rel="noopener">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-2.5">
          {footerNav.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    </nav>

    <!-- Newsletter -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="rounded-2xl bg-teal-600 p-6 sm:p-8 text-center">
        <h3 class="text-lg font-bold text-white sm:text-xl">Stay updated on Gulf expat life</h3>
        <p class="mt-1 text-sm text-white/80">Get notified when visa rules, cost of living, or relocation guides are updated. No spam.</p>
        <form id="newsletter-form" class="mt-4 flex flex-col sm:flex-row items-center justify-center gap-3 max-w-md mx-auto">
          <input type="email" id="newsletter-email" required placeholder="you@example.com" class="w-full sm:flex-1 rounded-xl border-0 px-4 py-3 text-sm text-gray-900 placeholder-gray-500 focus:ring-2 focus:ring-white/50" />
          <button type="submit" class="w-full sm:w-auto whitespace-nowrap rounded-xl bg-white text-teal-600 font-semibold px-6 py-3 text-sm hover:bg-gray-100 transition-colors">Subscribe</button>
        </form>
        <p id="newsletter-msg" class="mt-2 text-sm text-white/70 hidden"></p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-800">
      <div class="text-xs text-gray-400 dark:text-gray-500">
        &copy; {SITE.year} {SITE.name}. All rights reserved.
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const msg = document.getElementById('newsletter-msg');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (document.getElementById('newsletter-email') as HTMLInputElement)?.value;
    if (email && msg) {
      const subs = JSON.parse(localStorage.getItem('newsletter_subscribers') || '[]');
      if (!subs.includes(email)) { subs.push(email); localStorage.setItem('newsletter_subscribers', JSON.stringify(subs)); }
      msg.textContent = 'Thanks! You\'ll be notified of important updates.';
      msg.classList.remove('hidden');
      (document.getElementById('newsletter-email') as HTMLInputElement).value = '';
    }
  });
</script>

---
import { SITE } from "../../data/site-config";
import { footerNav } from "../../data/nav";
---

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Country Guides</h3>
        <ul class="space-y-2">
          {footerNav.countries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Calculators</h3>
        <ul class="space-y-2">
          {footerNav.calculators.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Resources</h3>
        <ul class="space-y-2">
          {footerNav.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Legal</h3>
        <ul class="space-y-2">
          {footerNav.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="text-sm text-gray-600 dark:text-gray-400">
          &copy; {SITE.year} {SITE.name}. All rights reserved.
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-500">
          Official {SITE.year} data &middot; 100% calculated in your browser &middot; Free
        </div>
      </div>
    </div>
  </div>
</footer>

      { title: "UAE Healthcare", desc: "Insurance, hospitals and medical costs for expats.", href: "/uae/healthcare/", tags: "uae healthcare insurance hospitals doctors" },
      { title: "UAE Housing & Rent", desc: "Rent prices, areas, Ejari process and tips.", href: "/uae/housing/", tags: "uae housing rent ejari apartments villas" },
      { title: "UAE Visa & Immigration", desc: "Emirates ID, visa types and immigration details.", href: "/uae/visa/", tags: "uae visa immigration emirates id" },
      { title: "UAE Transport", desc: "Metro, driving, Salik tolls and ride-hailing.", href: "/uae/transport/", tags: "uae transport metro driving salik rta" },
      { title: "UAE Banking", desc: "Bank accounts, remittances and credit cards for expats.", href: "/uae/banking/", tags: "uae banking accounts remittance credit cards" },
      { title: "UAE Telecom", desc: "du, Etisalat, mobile plans and internet setup.", href: "/uae/telecom/", tags: "uae telecom mobile internet du etisalat" },
      { title: "UAE Utilities", desc: "DEWA, ADDC setup, costs and tips.", href: "/uae/utilities/", tags: "uae utilities dewa addc electricity water" },
      // Qatar
      { title: "Qatar Expat Guide", desc: "Visa, housing, schools and cost of living in Qatar.", href: "/qatar/guide/", tags: "qatar doha guide overview" },
      { title: "Qatar Visa Guide", desc: "Work permit, residency and family sponsorship rules.", href: "/qatar/visa-guide/", tags: "qatar visa work permit residency sponsorship" },
      { title: "Qatar Cost of Living", desc: "Rent, groceries and prices in Doha with zero VAT.", href: "/qatar/cost-of-living/", tags: "qatar cost living rent prices doha budget" },

---
import { mainNav } from "../../data/nav";
---

<a href="#main-content" class="skip-to-content">Skip to content</a>
<header class="sticky top-0 z-50 bg-white dark:bg-gray-950 border-b border-gray-200 dark:border-gray-800">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0 group">
        <svg class="h-8 w-8 sm:h-9 sm:w-9 shrink-0" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="7" fill="#D97706"/>
          <text x="16" y="21" text-anchor="middle" font-family="system-ui,sans-serif" font-size="14" font-weight="800" fill="white" letter-spacing="0.5">AE</text>
        </svg>
        <div class="flex flex-col leading-none">
          <span class="text-base font-bold text-amber-600 dark:text-amber-400 group-hover:text-amber-700 dark:group-hover:text-amber-300 transition-colors">Arabia Expat</span>
          <span class="text-[10px] text-gray-500 dark:text-gray-400 font-medium tracking-wide">VISAS &middot; DAILY LIFE &middot; GUIDES</span>
        </div>
      </a>

      <!-- Desktop navigation -->
      <div class="hidden lg:flex items-center gap-0.5">
        {mainNav.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-teal-600 dark:hover:text-teal-400 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors inline-flex items-center gap-1"
            >
              {item.label}
              {item.children && (
                <svg class="h-3.5 w-3.5 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white dark:bg-gray-900 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 py-1.5 min-w-[240px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 hover:text-teal-600 dark:hover:text-teal-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
                    >
                      <span class="w-1 h-1 bg-gray-300 dark:bg-gray-600 rounded-full shrink-0"></span>
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Right side actions -->
      <div class="flex items-center gap-1.5">
        <!-- Search button -->
        <div class="relative">
          <button
            id="search-toggle"
            type="button"
            aria-label="Search"
            class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
            </svg>
          </button>

          <!-- Search dropdown panel -->
          <div id="search-panel" class="hidden absolute right-0 top-full mt-2 w-[340px] sm:w-[420px] bg-white dark:bg-gray-900 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 z-50 overflow-hidden">
            <div class="p-3 border-b border-gray-100 dark:border-gray-800">
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                </svg>
                <input
                  id="search-input"
                  type="text"
                  placeholder="Search guides, countries..."
                  autocomplete="off"
                  class="w-full pl-9 pr-10 py-2.5 text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                />
                <kbd class="hidden sm:inline-flex absolute right-3 top-1/2 -translate-y-1/2 items-center gap-0.5 px-1.5 py-0.5 text-[10px] font-medium text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 rounded border border-gray-200 dark:border-gray-600">
                  <span class="text-xs">&#8984;</span>K
                </kbd>
              </div>
            </div>
            <ul id="search-results" class="max-h-[360px] overflow-y-auto overscroll-contain">
              <li class="px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">Type to search&hellip;</li>
            </ul>
          </div>
        </div>

        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="h-5 w-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
          </svg>
          <svg class="h-5 w-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
          </svg>
        </button>

        <!-- Mobile menu toggle -->
        <button
          id="mobile-menu-toggle"
          type="button"
          aria-label="Toggle mobile menu"
          class="lg:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="h-6 w-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4 -mx-2">
      {mainNav.map((item) => (
        <div class="border-t border-gray-100 dark:border-gray-800 first:border-0">
          <a href={item.href} class="block px-4 py-3 text-sm font-semibold text-gray-800 dark:text-gray-200 hover:text-teal-600 dark:hover:text-teal-400 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-lg transition-colors">
            {item.label}
          </a>
          {item.children && (
            <div class="pl-4 pb-2 space-y-0.5">
              {item.children.map((child) => (
                <a href={child.href} class="block px-4 py-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 rounded-lg transition-colors">
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  document.getElementById("theme-toggle")?.addEventListener("click", function() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
  document.getElementById("mobile-menu-toggle")?.addEventListener("click", function() {
    const menu = document.getElementById("mobile-menu");
    const hamburger = document.getElementById("hamburger-icon");
    const close = document.getElementById("close-icon");
    if (menu && hamburger && close) {
      const isHidden = menu.classList.toggle("hidden");
      hamburger.classList.toggle("hidden", !isHidden);
      close.classList.toggle("hidden", isHidden);
    }
  });

  /* ── Client-side search (deferred to reduce TBT) ── */
  (window.requestIdleCallback||function(cb){setTimeout(cb,1)})(function() {
  (function() {
    var searchIndex = [
      { title: "Home", desc: "Your complete guide to living and working in the UAE, Qatar and Saudi Arabia.", href: "/", tags: "home gulf expat relocation" },
      // UAE
      { title: "UAE Expat Guide", desc: "Visa, housing, schools and cost of living in the UAE.", href: "/uae/guide/", tags: "uae emirates dubai abu dhabi guide overview" },

      { title: "Saudi Arabia Expat Guide", desc: "Visa, housing, jobs and Vision 2030 lifestyle.", href: "/saudi-arabia/guide/", tags: "saudi arabia ksa guide overview vision 2030" },
      { title: "Saudi Visa Guide", desc: "Iqama, Premium Residency and work visa rules.", href: "/saudi-arabia/visa-guide/", tags: "saudi visa iqama premium residency work permit" },
      { title: "Saudi Cost of Living", desc: "Riyadh and Jeddah rent, food and prices.", href: "/saudi-arabia/cost-of-living/", tags: "saudi cost living rent riyadh jeddah budget" },
      { title: "Riyadh City Guide", desc: "Vision 2030 epicenter: cost of living, entertainment and jobs.", href: "/saudi-arabia/riyadh/", tags: "riyadh city guide saudi capital" },
      { title: "Jeddah City Guide", desc: "Coastal lifestyle, industries and family living in Jeddah.", href: "/saudi-arabia/jeddah/", tags: "jeddah city guide saudi port" },

      { title: "Saudi Telecom", desc: "STC, Mobily, mobile plans and broadband.", href: "/saudi-arabia/telecom/", tags: "saudi telecom stc mobily mobile internet" },
      { title: "Saudi Utilities", desc: "SEC electricity, water setup and costs.", href: "/saudi-arabia/utilities/", tags: "saudi utilities sec electricity water" },
      // Cross-country guides
      { title: "Driving Licence Guide", desc: "Convert your licence or learn from scratch in UAE, Qatar and Saudi.", href: "/guides/driving-licence/", tags: "driving licence conversion rta test fees" },
      { title: "Utilities Setup Guide", desc: "DEWA, Kahramaa and SEC registration and costs.", href: "/guides/utilities-setup/", tags: "utilities setup dewa kahramaa sec electricity water" },
      { title: "Schools & Education Guide", desc: "Compare 700+ international schools across the Gulf.", href: "/guides/schools-education/", tags: "schools education fees khda international" },
      { title: "Mobile & Internet Guide", desc: "Compare du, Etisalat, Ooredoo, STC plans and eSIM.", href: "/guides/telecom-mobile/", tags: "mobile internet telecom esim plans" },
      { title: "Healthcare Guide", desc: "Insurance, hospitals and costs for Gulf expats.", href: "/guides/healthcare-expats-gulf/", tags: "healthcare insurance hospitals expat doctors" },
      { title: "Banking Guide", desc: "Bank accounts, remittances and credit cards in the Gulf.", href: "/guides/banking-expats-gulf/", tags: "banking accounts remittance credit cards" },
      { title: "Best Country for Expats", desc: "UAE vs Qatar vs Saudi Arabia compared for expats.", href: "/guides/best-country-for-expats-gulf/", tags: "best country comparison uae qatar saudi" },
      { title: "All Guides", desc: "Browse all expat guides for the Gulf region.", href: "/guides/", tags: "guides index all topics" },
      // Relocating from
      { title: "Relocating from India", desc: "Guide for Indian expats moving to the Gulf.", href: "/relocating-from/india/", tags: "relocating india gulf move" },
      { title: "Relocating from Pakistan", desc: "Guide for Pakistani expats moving to the Gulf.", href: "/relocating-from/pakistan/", tags: "relocating pakistan gulf move" },
      { title: "Relocating from Philippines", desc: "Guide for Filipino expats moving to the Gulf.", href: "/relocating-from/philippines/", tags: "relocating philippines gulf move" },
      { title: "Relocating from Egypt", desc: "Guide for Egyptian expats moving to the Gulf.", href: "/relocating-from/egypt/", tags: "relocating egypt gulf move" },
      { title: "Relocating from Bangladesh", desc: "Guide for Bangladeshi expats moving to the Gulf.", href: "/relocating-from/bangladesh/", tags: "relocating bangladesh gulf move" },
      { title: "Relocating from UK", desc: "Guide for British expats moving to the Gulf.", href: "/relocating-from/uk/", tags: "relocating uk british gulf move" },
      { title: "Relocating from USA", desc: "Guide for American expats moving to the Gulf.", href: "/relocating-from/usa/", tags: "relocating usa american gulf move" },
      { title: "Relocating from France", desc: "Guide for French expats moving to the Gulf.", href: "/relocating-from/france/", tags: "relocating france french gulf move" },
      // Other
      { title: "Glossary", desc: "Key terms for expats: Iqama, Emirates ID, Golden Visa, DEWA and more.", href: "/glossary/", tags: "glossary terms definitions" },
      { title: "News", desc: "Latest GCC expat policy changes and updates.", href: "/news/", tags: "news policy updates gcc" },
      { title: "GCC Policy Changes 2025", desc: "Golden Visa expansions, remote work permits and residency reforms.", href: "/news/gcc-expat-policy-changes-2025/", tags: "news policy golden visa remote work 2025" },
      { title: "About", desc: "Research standards, author credentials and methodology.", href: "/about/", tags: "about author methodology" },
      { title: "Methodology", desc: "Data sources and verification process.", href: "/methodology/", tags: "methodology data sources verification" },
    ];

    var panel = document.getElementById("search-panel");
    var input = document.getElementById("search-input");
    var resultsList = document.getElementById("search-results");
    var toggleBtn = document.getElementById("search-toggle");

    function openSearch() {
      panel.classList.remove("hidden");
      input.value = "";
      input.focus();
      renderResults("");
    }
    function closeSearch() {
      panel.classList.add("hidden");
    }
    function isOpen() {
      return !panel.classList.contains("hidden");
    }

    toggleBtn.addEventListener("click", function(e) {
      e.stopPropagation();
      if (isOpen()) { closeSearch(); } else { openSearch(); }
    });

    panel.addEventListener("click", function(e) { e.stopPropagation(); });

    document.addEventListener("click", function() { if (isOpen()) closeSearch(); });

    document.addEventListener("keydown", function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (isOpen()) { closeSearch(); } else { openSearch(); }
      }
      if (e.key === "Escape" && isOpen()) { closeSearch(); }
    });

    function renderResults(query) {
      var q = query.toLowerCase().trim();
      if (!q) {
        resultsList.innerHTML = '<li class="px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">Type to search&hellip;</li>';
        return;
      }
      var terms = q.split(/\s+/);
      var matches = searchIndex.filter(function(item) {
        var haystack = (item.title + " " + item.desc + " " + item.tags).toLowerCase();
        return terms.every(function(t) { return haystack.indexOf(t) !== -1; });
      });
      if (!matches.length) {
        resultsList.innerHTML = '<li class="px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">No results</li>';
        return;
      }
      resultsList.innerHTML = matches.slice(0, 8).map(function(item) {
        return '<li><a href="' + item.href + '" class="flex flex-col gap-0.5 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">' +
          '<span class="text-sm font-medium text-gray-900 dark:text-gray-100">' + escapeHtml(item.title) + '</span>' +
          '<span class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">' + escapeHtml(item.desc) + '</span>' +
          '</a></li>';
      }).join("");
    }

    function escapeHtml(str) {
      return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    input.addEventListener("input", function() { renderResults(this.value); });

    input.addEventListener("keydown", function(e) {
      if (e.key === "Enter") {
        var first = resultsList.querySelector("a");
        if (first) { window.location.href = first.getAttribute("href"); }
      }
    });
  })();
  });
</script>

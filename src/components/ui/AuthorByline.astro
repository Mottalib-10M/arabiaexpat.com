---
import { SITE } from "../../data/site-config";
---

<div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-6">
  <img src={SITE.author.image} alt={SITE.author.name} class="h-8 w-8 rounded-full object-cover" width="32" height="32" loading="lazy" />
  <span>By <span class="font-medium text-gray-700 dark:text-gray-300">{SITE.author.name}</span>, {SITE.author.credentials} &middot; Updated June 2026</span>
</div>

---
interface Props {
  faqs: { question: string; answer: string }[];
}
const { faqs } = Astro.props;
---

<section class="mt-12">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Frequently Asked Questions</h2>
  <div class="space-y-4">
    {faqs.map((faq, i) => (
      <details class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <summary class="flex items-center justify-between p-5 cursor-pointer text-left font-medium text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
          <span>{faq.question}</span>
          <svg class="h-5 w-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-5 pb-5 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
          <p>{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>

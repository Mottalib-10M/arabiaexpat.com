---
interface Props {
  faqs: { question: string; answer: string }[];
}
const { faqs } = Astro.props;
---

<section class="mt-12">
  <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-white mb-6">Frequently Asked Questions</h2>
  <div class="divide-y divide-gray-200 dark:divide-gray-800">
    {faqs.map((faq, i) => (
      <details class="group">
        <summary class="flex items-center justify-between py-4 cursor-pointer text-left font-medium text-gray-900 dark:text-white hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
          <span>{faq.question}</span>
          <svg class="h-5 w-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="pb-4 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
          <p>{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>

---
interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span>/</span>}
        {i === items.length - 1 ? (
          <span class="text-gray-900 dark:text-gray-100 font-medium">{item.name}</span>
        ) : (
          <a href={item.url} class="hover:text-teal-600 dark:hover:text-teal-400 transition-colors">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

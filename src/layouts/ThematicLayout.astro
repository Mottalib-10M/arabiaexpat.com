---
import Layout from "./Layout.astro";
import { SITE } from "../data/site-config";
import FAQAccordion from "../components/ui/FAQAccordion.astro";
import SourcesBlock from "../components/ui/SourcesBlock.astro";
import RelatedLinks from "../components/ui/RelatedLinks.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  schemas?: object[];
  breadcrumbs: { name: string; url: string }[];
  lastUpdated?: string;
  faqs?: { question: string; answer: string }[];
  sources?: { name: string; url: string }[];
  relatedLinks?: { label: string; href: string }[];
  crossLinks?: { label: string; href: string; description?: string }[];
}

const {
  title,
  description,
  canonical,
  schemas = [],
  breadcrumbs,
  lastUpdated = "June 2026",
  faqs = [],
  sources = [],
  relatedLinks = [],
  crossLinks = [],
} = Astro.props;
---

<Layout title={title} description={description} canonical={canonical} schemas={schemas}>
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-1.5">
            {i > 0 && <span>/</span>}
            {i === breadcrumbs.length - 1 ? (
              <span class="text-gray-900 dark:text-gray-100 font-medium">{crumb.name}</span>
            ) : (
              <a href={crumb.url} class="hover:text-teal-600 dark:hover:text-teal-400 transition-colors">{crumb.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <div class="mb-6 flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
      <img src={SITE.author.image} alt={SITE.author.name} class="h-8 w-8 rounded-full bg-gray-200 dark:bg-gray-700" width="32" height="32" />
      <span>By <strong class="text-gray-700 dark:text-gray-300">{SITE.author.name}</strong>, {SITE.author.credentials}</span>
      <span>&middot;</span>
      <time>Updated {lastUpdated}</time>
    </div>

    <!-- Simulator slot (rendered before content) -->
    <slot name="simulator" />

    <!-- Cross-links to same theme in other countries -->
    {crossLinks.length > 0 && (
      <nav class="mb-8 p-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg">
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Same topic in other countries</p>
        <div class="flex flex-wrap gap-2">
          {crossLinks.map((link) => (
            <a href={link.href} class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-teal-600 dark:text-teal-400 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-teal-400 dark:hover:border-teal-500 transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    )}

    <div class="prose prose-lg dark:prose-invert prose-teal max-w-none prose-headings:scroll-mt-20 prose-a:text-teal-600 dark:prose-a:text-teal-400">
      <slot />
    </div>

    {faqs.length > 0 && <FAQAccordion faqs={faqs} />}
    {sources.length > 0 && <SourcesBlock sources={sources} />}
    {relatedLinks.length > 0 && <RelatedLinks links={relatedLinks} />}

    <div class="mt-8 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400">
      <p>Official {SITE.year} data &middot; Written by {SITE.author.name}, {SITE.author.credentials} &middot; Last updated {lastUpdated}</p>
    </div>
  </article>
</Layout>

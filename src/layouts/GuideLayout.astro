---
import Layout from "./Layout.astro";
import AuthorByline from "../components/ui/AuthorByline.astro";
import { SITE } from "../data/site-config";

interface Props {
  title: string;
  description: string;
  canonical: string;
  schemas?: object[];
  breadcrumbs: { name: string; url: string }[];
  lastUpdated?: string;
}

const { title, description, canonical, schemas = [], breadcrumbs, lastUpdated = "June 2026" } = Astro.props;
---

<Layout title={title} description={description} canonical={canonical} schemas={schemas}>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-1.5">
            {i > 0 && <span>/</span>}
            {i === breadcrumbs.length - 1 ? (
              <span class="text-gray-900 dark:text-gray-100 font-medium">{crumb.name}</span>
            ) : (
              <a href={crumb.url} class="hover:text-teal-600 dark:hover:text-teal-400 transition-colors">{crumb.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <div class="prose prose-lg dark:prose-invert prose-teal max-w-none prose-headings:scroll-mt-20 prose-headings:font-serif prose-a:text-teal-600 dark:prose-a:text-teal-400">
      <slot />
    </div>

    <AuthorByline date={lastUpdated} />
  </article>
</Layout>

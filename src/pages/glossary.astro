---
import GuideLayout from "../layouts/GuideLayout.astro";
import { SITE } from "../data/site-config";
import { buildBreadcrumbs } from "../lib/seo";

const title = "Gulf Expat Glossary 2026: Key Terms for Living Abroad";
const description = "Clear definitions of residence visa, Emirates ID, iqama, Golden Visa, Salik, DEWA, labour ban, gratuity, and 35+ essential terms for expats in the Gulf.";
const canonical = "/glossary/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Glossary", url: "/glossary/" },
];

const defined = (term: string, def: string) => ({ term, def });

const terms = [
  defined("Absconding", "A legal status applied when an employee leaves their employer without following proper resignation procedures. In the GCC, absconding is reported to immigration authorities and can result in a labour ban, fines, and deportation. Employees accused of absconding may have difficulty obtaining future work permits in the region."),
  defined("ADEK (Abu Dhabi Department of Education and Knowledge)", "The government authority that regulates and oversees all private and public schools in the Emirate of Abu Dhabi. ADEK inspects schools, sets curriculum standards, and publishes school ratings. Expat parents use ADEK ratings to compare schools across Abu Dhabi, Al Ain, and the Western Region when choosing where to enrol their children."),
  defined("ADNOC Distribution", "The largest fuel and convenience retail network in the UAE, operating petrol stations, car washes, and convenience stores across the country. Expats use ADNOC Distribution stations for vehicle fuelling and shop purchases. ADNOC also offers prepaid fuel cards and a loyalty programme widely used by residents."),
  defined("Annual Leave", "Paid time off from work that employees are legally entitled to each year. In the UAE, employees receive 30 calendar days of annual leave after one year of service (two days per month during the first year). Saudi Arabia provides 21 days, increasing to 30 after five years. Qatar grants a minimum of three weeks. Unused leave can often be carried forward or paid out."),
  defined("Apostille", "An international certification that authenticates the origin of a public document (such as a degree, birth certificate, or marriage certificate) for use in another country. Under the Hague Convention, apostilled documents are accepted without further legalisation. Many GCC countries now accept apostilles, simplifying document authentication for expats."),
  defined("Attestation", "The process of getting official documents (degrees, certificates, marriage licences) verified and stamped by relevant authorities for use in a GCC country. Attestation typically involves authentication by the issuing country's foreign ministry, the destination country's embassy, and then the GCC country's foreign ministry. It is required for employment visas, school enrolment, and family sponsorship."),
  defined("Darb", "The road toll system operating in Abu Dhabi, similar to Salik in Dubai. Darb uses automatic number plate recognition to charge vehicles passing through toll gates on major roads. Expats register their vehicles through the Darb system, which deducts tolls from a prepaid account. Tolls are typically AED 4 per gate during peak hours."),
  defined("DEWA (Dubai Electricity and Water Authority)", "The government utility provider responsible for electricity and water supply in Dubai. Expats must register a DEWA account when moving into a new property, requiring an Ejari tenancy contract and a refundable security deposit. DEWA bills cover electricity consumption, water usage, sewerage, and a housing fee (5% of annual rent for tenants)."),
  defined("du", "One of the two main telecommunications providers in the UAE, alongside Etisalat (now e&). du offers mobile, broadband, and TV services to residents across the country. Expats can choose between prepaid and postpaid mobile plans, and du provides home internet packages typically ranging from 250 Mbps to 1 Gbps in urban areas."),
  defined("Emirates ID", "A mandatory national identity card issued to all UAE residents (citizens and expats) by the Federal Authority for Identity, Citizenship, Customs, and Port Security (ICP). The Emirates ID is required for almost every transaction in the UAE, including banking, health insurance, mobile registration, and government services. It must be renewed with the residence visa."),
  defined("Employment Visa", "A residence visa issued to a foreign national sponsored by a UAE, Saudi, or Qatari employer. The employment visa allows the holder to live and work legally in the country. The process typically involves a job offer, medical fitness test, Emirates ID registration (UAE) or iqama issuance (Saudi Arabia), and a labour card. It is usually valid for two to three years."),
  defined("Etisalat (e&)", "The largest telecommunications company in the UAE and one of the leading telecom operators in the Middle East. Etisalat provides mobile, broadband, and TV services. Expats register mobile SIM cards with their Emirates ID and can choose from prepaid or postpaid plans. Home internet speeds range from 250 Mbps to 2 Gbps depending on the package."),
  defined("Family Visa", "A residence visa that allows an expat worker to sponsor their spouse, children, and in some cases parents to live in a GCC country. In the UAE, the sponsoring employee must earn a minimum salary (currently AED 4,000/month plus accommodation, or AED 3,000/month with employer-provided housing). Children can be sponsored up to age 18 (25 if in full-time education)."),
  defined("Freelance Visa", "A residence visa that allows individuals to work independently in the UAE without being employed by a specific company. Freelance visas are issued by various free zones (such as Dubai's Tecom group, DAFZ, and Kiklabb) and permit holders to invoice clients directly. The visa typically includes health insurance and allows the holder to sponsor family members if income thresholds are met."),
  defined("Golden Visa", "A long-term UAE residence visa (5 or 10 years) available to investors, entrepreneurs, specialised talent, researchers, outstanding students, and humanitarian workers. Unlike standard visas, the Golden Visa is not tied to a specific employer and does not require a sponsor. Holders can stay outside the UAE for extended periods without losing their residency status."),
  defined("Good Conduct Certificate", "A police clearance document confirming that an individual has no criminal record in their home country or previous country of residence. GCC countries require good conduct certificates as part of the employment visa process for certain professions, including education, healthcare, and financial services. The certificate must typically be attested and translated into Arabic."),
  defined("Gratuity (End-of-Service)", "A lump-sum payment made to employees upon termination of employment. In the UAE, it is calculated as 21 days of basic salary per year for the first five years and 30 days per year thereafter, capped at two years of total salary. Saudi Arabia and Qatar have similar formulas. Gratuity is a key part of expat financial planning as it substitutes for a pension."),
  defined("Green Visa", "A self-sponsored UAE residence visa (5 years) that does not require employer sponsorship. The Green Visa is available to skilled employees (earning at least AED 15,000/month), self-employed freelancers, and investors. Holders can sponsor family members and have a 180-day grace period to remain in the UAE after the visa expires, rather than the standard 30 days."),
  defined("Iqama", "A residence permit issued to foreign nationals in Saudi Arabia, equivalent to the Emirates ID in the UAE. The iqama is tied to the sponsoring employer and must be renewed annually. It serves as the holder's primary identification document and is required for banking, renting property, driving, and accessing government services."),
  defined("Kafala (Sponsorship System)", "A legal framework used across the GCC that ties a foreign worker's immigration status to their employer (sponsor). The sponsor is responsible for the employee's visa, work permit, and legal status. While significant reforms in the UAE (2021) and Saudi Arabia have loosened restrictions, including allowing job mobility, the system still underpins much of GCC employment and residency law."),
  defined("Kahramaa (Qatar General Electricity and Water Corporation)", "The sole provider of electricity and water services in Qatar. Expats must register a Kahramaa account when renting a property, providing their QID and tenancy agreement. Kahramaa bills cover electricity and water consumption. A security deposit is required, and disconnection can occur for non-payment."),
  defined("KHDA (Knowledge and Human Development Authority)", "The regulatory authority for private education in Dubai. KHDA inspects and rates schools annually using a scale from Outstanding to Very Weak. Expat parents use KHDA inspection reports to compare schools, understand curriculum quality, and make informed enrolment decisions. KHDA also oversees higher education and training providers in Dubai."),
  defined("Labour Ban", "A restriction imposed by immigration authorities that prevents an employee from obtaining a new work permit in the same country for a specified period. Bans may result from absconding, contract violations, or non-completion of a minimum service period. The UAE has greatly reformed its ban system since 2022, and bans now apply only in limited circumstances."),
  defined("Mawaqif", "Abu Dhabi's paid parking system, managed by the Integrated Transport Centre (ITC). Mawaqif covers most public parking areas in Abu Dhabi city, with rates varying by zone. Expats can pay via SMS, the Darb app, or parking meters. Premium zones charge AED 3-4 per hour, while residential zones have lower rates and free periods."),
  defined("Medical Test", "A mandatory health screening required for all employment and residence visa applicants in GCC countries. The test typically includes a blood test (for HIV, hepatitis B and C, and syphilis), a chest X-ray (for tuberculosis), and a general fitness assessment. Applicants who fail the medical test may be denied a visa. Tests are conducted at government-approved medical centres."),
  defined("Ooredoo", "A major telecommunications provider operating in Qatar, Oman, and other markets. In Qatar, Ooredoo is the primary telecom operator, offering mobile, broadband, and TV services. Expats can register with their QID for postpaid plans or purchase prepaid SIM cards. Ooredoo provides home broadband via fibre with speeds up to 1 Gbps."),
  defined("PRO (Public Relations Officer)", "A professional who handles government-related paperwork and administrative tasks on behalf of individuals or companies in the GCC. PRO services include visa processing, Emirates ID applications, document attestation, driving licence transfers, and liaising with immigration, labour, and municipality authorities. Many expats use PRO services for complex bureaucratic procedures."),
  defined("QID (Qatar ID)", "The national identity card issued to all residents of Qatar, equivalent to the Emirates ID in the UAE. The QID is required for banking, renting property, registering utilities (Kahramaa), obtaining a driving licence, and accessing government services. It contains the holder's photo, QID number, nationality, and visa details, and must be renewed with the residence permit."),
  defined("Repatriation", "The return of an expatriate to their home country at the end of their employment contract. Under GCC labour law, the employer is generally responsible for the cost of the employee's repatriation flight. In the UAE, Saudi Arabia, and Qatar, this obligation extends to the employee's final departure unless they immediately take up new employment in the same country."),
  defined("Residence Visa", "The official document that permits a foreign national to live in a GCC country for a specified period. Residence visas are typically sponsored by an employer, family member, or property investment. In the UAE, standard residence visas are valid for two to three years and must be renewed before expiry. Overstaying results in daily fines."),
  defined("Salik", "Dubai's automatic road toll system that charges vehicles AED 4 each time they pass through a toll gate. There are currently eight Salik toll gates across Dubai. Expats must register their vehicle with Salik and maintain a prepaid balance. Salik tags are affixed to the windshield, and tolls are deducted automatically via radio-frequency identification (RFID)."),
  defined("School Fees", "The tuition and associated costs charged by private schools in the GCC. School fees in Dubai and Abu Dhabi are regulated by KHDA and ADEK respectively, with annual increases capped at a set percentage. Fees vary widely by curriculum (British, American, IB, Indian), with premium schools charging AED 40,000-100,000+ per year. Some employers include an education allowance to offset costs."),
  defined("SEC (Saudi Electricity Company)", "The primary electricity provider in Saudi Arabia, responsible for generation, transmission, and distribution of power across the Kingdom. Expats must register an SEC account when renting a property. Billing follows a tiered consumption model, with rates increasing at higher usage levels. SEC services can be managed through their online portal and mobile app."),
  defined("Sponsor", "A UAE national, GCC national, or authorised entity (company or free zone) that assumes legal responsibility for a foreign national's visa and residency status. In the employment context, the employer is the sponsor. For family visas, the working family member is the sponsor. The sponsor's obligations include visa costs, health insurance, and ensuring the sponsored person's legal compliance."),
  defined("Status Change", "The process of converting one type of visa to another within a GCC country, without leaving and re-entering. In the UAE, a common status change is from a visit visa to an employment visa. Status changes are processed through immigration authorities and require the new sponsor (employer) to apply on the employee's behalf. Processing typically takes one to two weeks."),
  defined("STC (Saudi Telecom Company)", "The largest telecommunications operator in Saudi Arabia, providing mobile, broadband, and enterprise services. STC offers prepaid and postpaid mobile plans, home fibre broadband, and IPTV. Expats register with their iqama and can choose from various data and call packages. STC also operates in other markets under the stc group brand."),
  defined("Visit Visa", "A short-term visa that allows a foreign national to enter a GCC country for tourism, business meetings, or family visits. Visit visa durations range from 14 to 90 days depending on nationality and visa type. Some nationalities receive visa-on-arrival in the UAE. Visit visas generally do not permit employment, and overstaying results in daily fines and potential entry bans."),
  defined("WPS (Wage Protection System)", "An electronic salary transfer system used in the UAE and Saudi Arabia to ensure employers pay wages on time and in full. Employers must transfer salaries through approved banks or exchange houses, and the system alerts authorities to late or missing payments. Non-compliance can result in fines, work permit restrictions, and licence suspension for the employer."),
];

const letters = [...new Set(terms.map(t => t.term[0].toUpperCase()))].sort();

const definedTermSetSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": title,
  "description": description,
  "url": `${SITE.url}/glossary/`,
  "inLanguage": "en",
  "hasDefinedTerm": terms.map(t => ({
    "@type": "DefinedTerm",
    "name": t.term,
    "description": t.def,
  })),
};

const schemas = [
  definedTermSetSchema,
  buildBreadcrumbs([
    { name: "Home", url: SITE.url + "/" },
    { name: "Glossary", url: SITE.url + "/glossary/" },
  ]),
];
---

<GuideLayout
  title={title}
  description={description}
  canonical={canonical}
  schemas={schemas}
  breadcrumbs={breadcrumbs}
>
  <h1>Gulf Expat Glossary</h1>
  <p class="lead">Key employment, visa, utilities, and daily-life terms for expatriates working and living in the UAE, Qatar, and Saudi Arabia.</p>

  <nav aria-label="Alphabetical navigation" class="not-prose mb-8 flex flex-wrap gap-2">
    {letters.map(letter => (
      <a href={`#letter-${letter}`} class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-sm font-semibold text-gray-700 dark:text-gray-300 hover:bg-teal-50 dark:hover:bg-teal-900/20 hover:border-teal-400 transition-colors">
        {letter}
      </a>
    ))}
  </nav>

  {letters.map(letter => {
    const letterTerms = terms.filter(t => t.term[0].toUpperCase() === letter);
    return (
      <section id={`letter-${letter}`} class="scroll-mt-20">
        <h2>{letter}</h2>
        <dl class="not-prose space-y-6 mb-8">
          {letterTerms.map(t => (
            <div>
              <dt class="text-lg font-semibold text-gray-900 dark:text-gray-100">{t.term}</dt>
              <dd class="mt-1 text-gray-600 dark:text-gray-400 leading-relaxed">{t.def}</dd>
            </div>
          ))}
        </dl>
      </section>
    );
  })}

  <div class="not-prose mt-12 rounded-xl border border-teal-200 dark:border-teal-800 bg-teal-50 dark:bg-teal-900/20 p-6 text-center">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Plan Your Move to the Gulf</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-4">Read our in-depth country guides covering visas, housing, healthcare, schools, and daily life for expats.</p>
    <a href="/guides/" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-teal-600 text-white font-semibold hover:bg-teal-700 transition-colors">
      Browse All Guides
    </a>
  </div>

  <h2>Related Resources</h2>
  <ul>
    <li><a href="/uae/guide/">UAE Expat Guide 2026</a></li>
    <li><a href="/saudi-arabia/guide/">Saudi Arabia Expat Guide 2026</a></li>
    <li><a href="/qatar/guide/">Qatar Expat Guide 2026</a></li>
    <li><a href="/guides/">All Guides</a></li>
  </ul>
</GuideLayout>

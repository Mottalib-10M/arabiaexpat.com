---
import Layout from "../layouts/Layout.astro";
import { SITE, COUNTRIES } from "../data/site-config";
import { buildOrganizationSchema, buildWebSiteSchema } from "../lib/seo";
import TrustBadge from "../components/ui/TrustBadge.astro";

const schemas = [buildOrganizationSchema(), buildWebSiteSchema()];
---

<Layout
  title="Gulf Salaries, Gratuity Calculators and Guides 2026"
  description="Compare salaries, calculate gratuity, and plan your move to the UAE, Qatar, or Saudi Arabia. Free 2026 salary data for 20+ professions across 3 Gulf countries."
  canonical="/"
  schemas={schemas}
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-teal-600 to-teal-800 dark:from-teal-900 dark:to-gray-950 text-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <TrustBadge />
      <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        Your Complete Gulf Expat Guide 2026
      </h1>
      <p class="mt-4 text-xl text-teal-100 max-w-2xl mx-auto">
        Salary data, gratuity calculators, visa guides, and cost of living comparisons for the UAE, Qatar, and Saudi Arabia. Everything you need to plan your Gulf career.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/uae/salaries/" class="px-6 py-3 bg-gold-600 hover:bg-gold-700 text-white font-semibold rounded-lg transition-colors">
          Browse Salaries
        </a>
        <a href="/uae/gratuity-calculator/" class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg border border-white/20 transition-colors">
          Calculate Gratuity
        </a>
      </div>
    </div>
  </section>

  <!-- Country Cards -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">
        Choose Your Destination
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {Object.values(COUNTRIES).map((c) => (
          <a href={`/${c.slug}/guide/`} class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-8 hover:shadow-lg hover:border-teal-300 dark:hover:border-teal-600 transition-all">
            <div class="text-4xl mb-4">{c.flag === "AE" ? "\u{1F1E6}\u{1F1EA}" : c.flag === "QA" ? "\u{1F1F6}\u{1F1E6}" : "\u{1F1F8}\u{1F1E6}"}</div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{c.fullName}</h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
              Salary data for 20 professions, gratuity calculator, visa guide, cost of living, and labor law essentials.
            </p>
            <div class="mt-4 text-sm text-gray-500 dark:text-gray-500">
              Currency: {c.currency} ({c.currencyName})
            </div>
            <div class="mt-4 flex items-center gap-2 text-teal-600 dark:text-teal-400 text-sm font-medium">
              Explore {c.name} &rarr;
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Calculators -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-4">
        Free Financial Calculators
      </h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-12 max-w-2xl mx-auto">
        Calculate your end-of-service benefits and take-home pay. All calculations run in your browser with official 2026 formulas.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: "UAE Gratuity Calculator", href: "/uae/gratuity-calculator/", desc: "Calculate your UAE end-of-service benefits using official MoHRE formulas for limited and unlimited contracts." },
          { title: "Saudi Gratuity Calculator", href: "/saudi-arabia/gratuity-calculator/", desc: "Compute Saudi EOSB with half-month and full-month calculations per MHRSD guidelines." },
          { title: "Qatar Gratuity Calculator", href: "/qatar/gratuity-calculator/", desc: "Estimate your Qatar end-of-service gratuity based on MADLSA minimum entitlements." },
          { title: "UAE Salary Calculator", href: "/uae/salary-calculator/", desc: "Break down your UAE package into base, housing, transport. Zero income tax for expats." },
          { title: "Saudi Salary Calculator", href: "/saudi-arabia/salary-calculator/", desc: "Calculate take-home pay with GOSI deductions for nationals and expat employer contributions." },
          { title: "Qatar Salary Calculator", href: "/qatar/salary-calculator/", desc: "Full salary breakdown in a zero-tax, zero-contribution environment for expatriates." },
        ].map((calc) => (
          <a href={calc.href} class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md hover:border-teal-300 dark:hover:border-teal-600 transition-all">
            <h3 class="font-bold text-gray-900 dark:text-white">{calc.title}</h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{calc.desc}</p>
            <span class="mt-3 inline-block text-teal-600 dark:text-teal-400 text-sm font-medium">
              Open Calculator &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Guides -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">
        Essential Expat Guides
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: "UAE Visa Guide 2026", href: "/uae/visa-guide/", desc: "Employment, Golden, Green, and Freelancer visas explained." },
          { title: "Saudi Labor Law 2026", href: "/saudi-arabia/labor-law/", desc: "Working hours, leave, termination, and Saudization essentials." },
          { title: "Relocating from India", href: "/relocating-from/india/", desc: "Complete guide for Indian professionals moving to the Gulf." },
          { title: "UAE Cost of Living", href: "/uae/cost-of-living/", desc: "Dubai and Abu Dhabi rent, food, transport, and school fees." },
          { title: "Qatar Expat Guide", href: "/qatar/guide/", desc: "Everything you need for life and work in Qatar." },
          { title: "Saudi Salaries 2026", href: "/saudi-arabia/salaries/", desc: "Salary data for 20 professions in the Kingdom." },
          { title: "Relocating from UK", href: "/relocating-from/uk/", desc: "Tax planning, schools, and lifestyle for British expats." },
          { title: "Qatar Labor Law", href: "/qatar/labor-law/", desc: "Minimum wage, contracts, and worker protections." },
        ].map((guide) => (
          <a href={guide.href} class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5 hover:shadow-md hover:border-teal-300 dark:hover:border-teal-600 transition-all">
            <h3 class="font-semibold text-gray-900 dark:text-white text-sm">{guide.title}</h3>
            <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Author/Trust Section -->
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <img src={SITE.author.image} alt={SITE.author.name} class="mx-auto h-16 w-16 rounded-full bg-gray-200 dark:bg-gray-700" width="64" height="64" />
      <h2 class="mt-4 text-xl font-bold text-gray-900 dark:text-white">{SITE.author.name}, {SITE.author.credentials}</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400 text-sm max-w-lg mx-auto">
        {SITE.author.bio}
      </p>
      <a href="/about/" class="mt-4 inline-block text-teal-600 dark:text-teal-400 text-sm font-medium hover:underline">
        Learn more about our methodology &rarr;
      </a>
    </div>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { SITE, COUNTRIES } from "../data/site-config";
import { buildOrganizationSchema, buildWebSiteSchema, buildFAQSchema } from "../lib/seo";
import FAQAccordion from "../components/ui/FAQAccordion.astro";

const faqs = [
  { question: "What do I need to know before moving to the Gulf in 2026?", answer: "Before relocating to the UAE, Qatar, or Saudi Arabia, research visa requirements (your employer typically sponsors your work visa), housing options and costs, healthcare and insurance (employer-provided), schooling for children if applicable, and the cultural environment. Each country has different processes for setting up utilities, getting a driving licence, and opening a bank account. Our country guides walk you through each step." },
  { question: "How do I set up utilities when I arrive in Dubai?", answer: "In Dubai, you register with DEWA (Dubai Electricity and Water Authority) for electricity and water. You need your tenancy contract, passport copy, and Emirates ID. In Abu Dhabi, the equivalent is ADDC. For internet and mobile, du and Etisalat (e&) are the two providers. Most setups can be done online or at service centers within a few days of arrival." },
  { question: "Which Gulf country is best for expat families?", answer: "The UAE, particularly Dubai, is widely considered the best Gulf country for families due to its extensive international school network (600+ schools), world-class healthcare, safe environment, and abundant recreational options. Qatar offers a compact, family-friendly lifestyle with lower costs. Saudi Arabia is rapidly improving with new entertainment venues and social reforms under Vision 2030." },
  { question: "Can I drive with my foreign licence in the Gulf?", answer: "Rules vary by country. The UAE allows licence conversion without a driving test for citizens of certain countries (UK, US, Canada, most EU). Others must take lessons and pass a test. Qatar requires a local licence, with conversion available for some nationalities. Saudi Arabia also allows conversion for selected countries. Our driving licence guide covers the full process for each country." },
  { question: "What are the best international schools in the Gulf?", answer: "Top international schools include GEMS, Taaleem, and Aldar Academies in the UAE; Qatar Academy and Doha College in Qatar; and the British and American international schools across Saudi Arabia. Curricula available include British, American, IB, Indian (CBSE/ICSE), and French. School fees range from AED 15,000 (~€3,750) to AED 100,000+ (~€25,000+) per year depending on the school tier." },
  { question: "How much does it cost to live in the Gulf as an expat?", answer: "Costs vary widely. Dubai is the most expensive: one-bedroom apartments cost AED 7,000-10,000 (~€1,750-2,500)/month. Riyadh is 20-30% cheaper. Doha falls in between. Groceries, dining, and transport follow similar patterns. For detailed breakdowns, see our cost-of-living guides for each country." },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mottalib Radif",
  "jobTitle": "Personal Finance Enthusiast",
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "INSEAD"
  },
  "url": "https://arabiaexpat.com/about/"
};

const schemas = [buildOrganizationSchema(), buildWebSiteSchema(), buildFAQSchema(faqs), personSchema];

const countrySummaries = {
  uae: "600+ international schools, Golden Visa residency, DEWA/ADDC utility setup. The most established expat destination in the region.",
  qatar: "Zero VAT, compact city lifestyle, World Cup legacy infrastructure. Kahramaa utilities and QID process.",
  saudi: "Vision 2030 transformation, Premium Residency options, Riyadh Metro now operational. Fastest-growing expat market.",
};
const countryExpats = { uae: "8.9M", qatar: "2.4M", saudi: "10.4M" };
---

<Layout
  title="Living in the Gulf 2026 | Visa, Housing & Schools Guide"
  description="Plan your move to UAE, Qatar or Saudi Arabia with 2026 data on visas, rent, school fees, utilities and driving licences. Over 30M expats use these countries."
  canonical="/"
  schemas={schemas}
>
  <!-- Masthead -->
  <div class="border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 lg:py-10">
      <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white tracking-tight leading-tight max-w-3xl">
        Your complete guide to expat life in the Gulf
      </h1>
      <p class="mt-3 text-gray-500 dark:text-gray-400 max-w-2xl">
        Visa processes, housing, schools, driving licences, utilities, and daily life in the UAE, Qatar, and Saudi Arabia. Updated June 2026.
      </p>
    </div>
  </div>

  <!-- Main content: newspaper-style 2/3 + 1/3 -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-3 lg:gap-12">

      <!-- Left column: main content -->
      <div class="lg:col-span-2">
        <!-- Country guides -->
        <section>
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white pb-2 border-b-2 border-gray-900 dark:border-white mb-4">Country Guides</h2>
          <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {Object.entries(COUNTRIES).map(([key, c]) => (
                <article>
                  <a href={`/${c.slug}/guide/`} class="group flex items-start justify-between gap-4 py-4 px-3 -mx-3 rounded hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                    <div>
                      <div class="flex items-baseline gap-3">
                        <span class="text-xl">{c.flag === "AE" ? "\u{1F1E6}\u{1F1EA}" : c.flag === "QA" ? "\u{1F1F6}\u{1F1E6}" : "\u{1F1F8}\u{1F1E6}"}</span>
                        <h3 class="text-lg font-bold text-teal-700 dark:text-teal-400 underline decoration-teal-200 dark:decoration-teal-800 underline-offset-2 group-hover:decoration-teal-500 transition-colors">
                          {c.fullName}
                        </h3>
                        <span class="text-sm text-gray-400">{countryExpats[key as keyof typeof countryExpats]} expats</span>
                      </div>
                      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed ml-9">{countrySummaries[key as keyof typeof countrySummaries]}</p>
                    </div>
                    <svg class="h-5 w-5 text-gray-400 dark:text-gray-500 group-hover:text-teal-600 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </article>
            ))}
          </div>
        </section>

        <!-- Practical guides -->
        <section class="mt-10">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white pb-2 border-b-2 border-gray-900 dark:border-white mb-4">Practical Guides</h2>
          <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {[
              { title: "Driving Licence Guide 2026", href: "/guides/driving-licence/", desc: "Licence conversion, driving schools, costs, and requirements across UAE, Qatar, Saudi." },
              { title: "Utilities Setup Guide", href: "/guides/utilities-setup/", desc: "DEWA, ADDC, Kahramaa, SEC. How to connect electricity, water, and internet." },
              { title: "Schools & Education 2026", href: "/guides/schools-education/", desc: "International school systems, curricula, fees, KHDA ratings, and university options." },
              { title: "Mobile & Internet Guide", href: "/guides/telecom-mobile/", desc: "du, Etisalat, Ooredoo, STC. Plans, costs, eSIM, and home broadband options." },
              { title: "Healthcare for Expats", href: "/guides/healthcare-expats-gulf/", desc: "Insurance, hospitals, pharmacies, and emergency care across the Gulf." },
              { title: "Banking for Expats", href: "/guides/banking-expats-gulf/", desc: "Opening accounts, remittances, credit cards, and digital banking." },
            ].map((guide) => (
              <a href={guide.href} class="flex items-center justify-between py-3 px-3 -mx-3 rounded group gap-4 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                <div>
                  <h3 class="text-sm font-semibold text-teal-700 dark:text-teal-400 underline decoration-teal-200 dark:decoration-teal-800 underline-offset-2 group-hover:decoration-teal-500 transition-colors">{guide.title}</h3>
                  <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">{guide.desc}</p>
                </div>
                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500 group-hover:text-teal-600 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>

        <!-- Cost of living & comparisons -->
        <section class="mt-10">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white pb-2 border-b-2 border-gray-900 dark:border-white mb-4">Cost of Living & Data</h2>
          <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {[
              { title: "UAE Cost of Living", href: "/uae/cost-of-living/", desc: "Interactive simulator: rent, groceries, transport, and school fees in Dubai and Abu Dhabi." },
              { title: "Qatar Cost of Living", href: "/qatar/cost-of-living/", desc: "Monthly costs in Doha with comparison tool for 15 origin cities." },
              { title: "Saudi Arabia Cost of Living", href: "/saudi-arabia/cost-of-living/", desc: "Costs in Riyadh, Jeddah, and Dammam with interactive estimator." },
              { title: "UAE Housing Guide", href: "/uae/housing/", desc: "Rent estimator, neighborhoods, Ejari registration, and rental tips." },
              { title: "Best Country for Expats", href: "/guides/best-country-for-expats-gulf/", desc: "UAE vs Qatar vs Saudi Arabia: lifestyle, cost, and opportunity compared." },
            ].map((guide) => (
              <a href={guide.href} class="flex items-center justify-between py-3 px-3 -mx-3 rounded group gap-4 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                <div>
                  <h3 class="text-sm font-semibold text-teal-700 dark:text-teal-400 underline decoration-teal-200 dark:decoration-teal-800 underline-offset-2 group-hover:decoration-teal-500 transition-colors">{guide.title}</h3>
                  <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">{guide.desc}</p>
                </div>
                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500 group-hover:text-teal-600 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>

        <!-- Why the Gulf - editorial prose -->
        <section class="mt-10">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white pb-2 border-b-2 border-gray-900 dark:border-white mb-4">Why the Gulf in 2026</h2>
          <div class="prose prose-sm dark:prose-invert max-w-none text-gray-600 dark:text-gray-400">
            <p>The Gulf Cooperation Council countries attract over 30 million expatriate workers. The UAE alone hosts 8.9 million foreign residents, 88% of its total population. Saudi Arabia's Vision 2030 program has created thousands of new roles across technology, entertainment, tourism, and infrastructure. Qatar's post-World Cup economy is expanding into finance, education, and LNG production.</p>
            <p>Setting up your life involves practical steps that differ from country to country: obtaining your residence visa, finding housing, connecting electricity and water, getting a local SIM card, opening a bank account, converting your driving licence, and enrolling children in school. Our guides walk through each step with current 2026 data.</p>
          </div>
        </section>
      </div>

      <!-- Right column: sidebar -->
      <aside class="mt-10 lg:mt-0">
        <!-- Calculators -->
        <div class="mb-8">
          <h3 class="text-xs font-bold text-gray-900 dark:text-white uppercase tracking-wider pb-2 border-b border-gray-200 dark:border-gray-800 mb-3">Tools & Calculators</h3>
          <ul class="space-y-2">
            {[
              { label: "Cost of Living Simulator", href: "/uae/cost-of-living/" },
              { label: "Salary Calculator", href: "/uae/salary-calculator/" },
              { label: "Gratuity Calculator", href: "/uae/gratuity-calculator/" },
              { label: "UAE Education Guide", href: "/uae/education/" },
              { label: "All Calculators", href: "/calculators/" },
            ].map((link) => (
              <li>
                <a href={link.href} class="text-sm text-teal-700 dark:text-teal-400 underline decoration-teal-200 dark:decoration-teal-800 underline-offset-2 hover:decoration-teal-500 transition-colors">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Relocating from -->
        <div class="mb-8">
          <h3 class="text-xs font-bold text-gray-900 dark:text-white uppercase tracking-wider pb-2 border-b border-gray-200 dark:border-gray-800 mb-3">Relocating From</h3>
          <ul class="space-y-2">
            {[
              { label: "India → Gulf", href: "/relocating-from/india/" },
              { label: "Pakistan → Gulf", href: "/relocating-from/pakistan/" },
              { label: "UK → Gulf", href: "/relocating-from/uk/" },
              { label: "USA → Gulf", href: "/relocating-from/usa/" },
              { label: "France → Gulf", href: "/relocating-from/france/" },
              { label: "Philippines → Gulf", href: "/relocating-from/philippines/" },
              { label: "Egypt → Gulf", href: "/relocating-from/egypt/" },
            ].map((link) => (
              <li>
                <a href={link.href} class="text-sm text-teal-700 dark:text-teal-400 underline decoration-teal-200 dark:decoration-teal-800 underline-offset-2 hover:decoration-teal-500 transition-colors">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Sister sites -->
        <div class="mb-8">
          <h3 class="text-xs font-bold text-gray-900 dark:text-white uppercase tracking-wider pb-2 border-b border-gray-200 dark:border-gray-800 mb-3">From Our Network</h3>
          <ul class="space-y-3">
            <li>
              <a href="https://taxfreesalaries.com/" target="_blank" rel="noopener" class="group">
                <span class="block text-sm font-medium text-gray-900 dark:text-white group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors">Salary & Employment Data</span>
                <span class="text-xs text-gray-400">taxfreesalaries.com</span>
              </a>
            </li>
            <li>
              <a href="https://thedubaisetup.com/" target="_blank" rel="noopener" class="group">
                <span class="block text-sm font-medium text-gray-900 dark:text-white group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors">Business Setup Guides</span>
                <span class="text-xs text-gray-400">thedubaisetup.com</span>
              </a>
            </li>
            <li>
              <a href="https://uaepriceindex.com/" target="_blank" rel="noopener" class="group">
                <span class="block text-sm font-medium text-gray-900 dark:text-white group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors">Property Prices</span>
                <span class="text-xs text-gray-400">uaepriceindex.com</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- About -->
        <div class="border border-gray-200 dark:border-gray-800 rounded p-4">
          <div class="flex items-center gap-3 mb-2">
            <img
              src={SITE.author.image}
              alt={SITE.author.name}
              class="h-10 w-10 rounded bg-gray-200 dark:bg-gray-700 object-cover"
              width="40"
              height="40"
            />
            <div>
              <div class="text-sm font-bold text-gray-900 dark:text-white">{SITE.author.name}</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">{SITE.author.credentials}</div>
            </div>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{SITE.author.bio}</p>
          <a href="/about/" class="mt-2 inline-block text-xs text-gray-500 dark:text-gray-400 hover:text-teal-700 dark:hover:text-teal-400 transition-colors">About & methodology &rarr;</a>
        </div>
      </aside>
    </div>
  </div>

  <!-- FAQ -->
  <div class="border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-10">
      <FAQAccordion faqs={faqs} />
    </div>
  </div>
</Layout>

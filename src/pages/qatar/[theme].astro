---
import ThematicLayout from "../../layouts/ThematicLayout.astro";
import { getThematicPagesForCountry, getCrossLinks } from "../../data/thematic-registry";
import { buildBreadcrumbs, buildArticleSchema, buildFAQSchema } from "../../lib/seo";
import SchoolCostEstimator from "../../components/calculators/SchoolCostEstimator";
import RentEstimator from "../../components/calculators/RentEstimator";
import TransportCostEstimator from "../../components/calculators/TransportCostEstimator";
import UtilitiesCostEstimator from "../../components/calculators/UtilitiesCostEstimator";

export function getStaticPaths() {
  const pages = getThematicPagesForCountry("qatar");
  return pages.map((page) => ({
    params: { theme: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const crossLinks = getCrossLinks(page);

const breadcrumbs = [
  { name: "Home", url: "https://arabiaexpat.com/" },
  { name: "Qatar", url: "https://arabiaexpat.com/qatar/guide/" },
  { name: page.title, url: `https://arabiaexpat.com/qatar/${page.slug}/` },
];
---

<ThematicLayout
  title={page.title}
  description={page.description}
  canonical={`/qatar/${page.slug}/`}
  schemas={[buildBreadcrumbs(breadcrumbs), buildArticleSchema(page.title, page.description, `https://arabiaexpat.com/qatar/${page.slug}/`, "2025-06-01", "2026-06-15"), buildFAQSchema(page.faqs)]}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Qatar", url: "/qatar/guide/" }, { name: page.title.replace(/^Qatar\s+/i, "").replace(/\s+in Qatar.*$/i, ""), url: `/qatar/${page.slug}/` }]}
  faqs={page.faqs}
  sources={page.sources}
  relatedLinks={page.relatedLinks}
  crossLinks={crossLinks}
>
  <Fragment slot="simulator">
    {page.calculator === "education" && <SchoolCostEstimator client:load countryKey="qatar" currency="QAR" />}
    {page.calculator === "housing" && <RentEstimator client:load countryKey="qatar" currency="QAR" />}
    {page.calculator === "transport" && <TransportCostEstimator client:load countryKey="qatar" currency="QAR" />}
    {page.calculator === "utilities" && <UtilitiesCostEstimator client:load countryKey="qatar" currency="QAR" />}
  </Fragment>

  <h1>{page.title}</h1>

  {page.intro.split("\n\n").map((p) => <p>{p}</p>)}

  {page.citySections.map((section) => (
    <>
      <h2 id={section.slug}>{section.city}</h2>
      {section.content.split("\n\n").map((p) => <p>{p}</p>)}
    </>
  ))}
</ThematicLayout>

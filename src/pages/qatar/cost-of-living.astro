---
import GuideLayout from "../../layouts/GuideLayout.astro";
import { qatarCostOfLiving } from "../../data/qatar/cost-of-living";
import { buildBreadcrumbs } from "../../lib/seo";
import RelatedLinks from "../../components/ui/RelatedLinks.astro";
import SourcesBlock from "../../components/ui/SourcesBlock.astro";
const breadcrumbs = [{ name: "Home", url: "https://gulfexpathub.com/" }, { name: "Qatar", url: "https://gulfexpathub.com/qatar/guide/" }, { name: "Cost of Living", url: "https://gulfexpathub.com/qatar/cost-of-living/" }];
---
<GuideLayout title="Qatar Cost of Living 2026: Doha Prices Guide" description="Detailed Qatar cost of living guide for 2026. Rent, food, transport, healthcare, and education prices in Doha with QAR and USD equivalents." canonical="/qatar/cost-of-living/" schemas={[buildBreadcrumbs(breadcrumbs)]} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Qatar", url: "/qatar/guide/" }, { name: "Cost of Living", url: "/qatar/cost-of-living/" }]}>
<h1>Qatar Cost of Living in 2026: Doha Price Guide</h1>
<p>Qatar offers a unique cost-of-living proposition: no income tax, no VAT, and living costs generally lower than Dubai. Doha is the center of all economic activity, and nearly all expatriates live in the capital or its immediate suburbs. Housing is the largest expense, followed by education (for families) and food. This guide provides current 2026 pricing for all major expense categories, helping you budget accurately before and during your Qatar assignment.</p>
{qatarCostOfLiving.cities.map((city) => (
<>
<h2>{city.name} Cost Breakdown</h2>
<h3>Housing</h3>
<div class="not-prose overflow-x-auto mb-4">
<table class="w-full text-sm"><thead><tr class="bg-teal-600 text-white"><th class="px-3 py-2 text-left rounded-tl-lg">Type</th><th class="px-3 py-2 text-right">Min (QAR)</th><th class="px-3 py-2 text-right">Max (QAR)</th><th class="px-3 py-2 text-right rounded-tr-lg">USD Equiv.</th></tr></thead>
<tbody class="divide-y divide-gray-100 dark:divide-gray-800">
<tr><td class="px-3 py-2">Studio</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.studioApartment.min.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.studioApartment.max.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">${Math.round(city.housing.studioApartment.min / 3.64).toLocaleString()}-${Math.round(city.housing.studioApartment.max / 3.64).toLocaleString()}</td></tr>
<tr><td class="px-3 py-2">1 Bedroom</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.oneBedroom.min.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.oneBedroom.max.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">${Math.round(city.housing.oneBedroom.min / 3.64).toLocaleString()}-${Math.round(city.housing.oneBedroom.max / 3.64).toLocaleString()}</td></tr>
<tr><td class="px-3 py-2">2 Bedroom</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.twoBedroom.min.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.twoBedroom.max.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">${Math.round(city.housing.twoBedroom.min / 3.64).toLocaleString()}-${Math.round(city.housing.twoBedroom.max / 3.64).toLocaleString()}</td></tr>
<tr><td class="px-3 py-2">Family Villa</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.familyVilla.min.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">{city.housing.familyVilla.max.toLocaleString()}</td><td class="px-3 py-2 text-right tabular-nums">${Math.round(city.housing.familyVilla.min / 3.64).toLocaleString()}-${Math.round(city.housing.familyVilla.max / 3.64).toLocaleString()}</td></tr>
</tbody></table>
</div>
<p>Food: Groceries QAR {city.food.groceriesMonthly.min.toLocaleString()}-{city.food.groceriesMonthly.max.toLocaleString()}/mo. Budget dining QAR {city.food.mealBudgetRestaurant.min}-{city.food.mealBudgetRestaurant.max}. Mid-range QAR {city.food.mealMidRange.min}-{city.food.mealMidRange.max}. Transport: Metro pass QAR {city.transport.metroMonthlyPass.amount}. Petrol QAR {city.transport.gasolinePerLiter.amount}/L. Healthcare: GP visit QAR {city.healthcare.gpVisit.min}-{city.healthcare.gpVisit.max}. Education: School QAR {city.education.internationalSchool.min.toLocaleString()}-{city.education.internationalSchool.max.toLocaleString()}/yr. Utilities: QAR {city.utilities.monthly.min}-{city.utilities.monthly.max}/mo.</p>
</>
))}
<SourcesBlock sources={[{ name: "Kahramaa Qatar", url: "https://www.km.qa/" }]} />
<RelatedLinks links={[{ label: "Qatar Salaries", href: "/qatar/salaries/" }, { label: "Qatar Salary Calculator", href: "/qatar/salary-calculator/" }, { label: "Qatar Guide", href: "/qatar/guide/" }]} />
</GuideLayout>

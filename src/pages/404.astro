---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found — Browse Our Gulf Expat Guides Instead"
  description="This page does not exist or has moved. Explore visa guides, cost of living data, school directories and driving licence info for UAE, Qatar and Saudi Arabia."
  canonical="/404/"
  noindex={true}
>
  <div class="mx-auto max-w-2xl px-4 py-24 text-center">
    <p class="text-6xl font-bold text-teal-600 dark:text-teal-400">404</p>
    <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Page Not Found</h1>
    <p class="mt-4 text-gray-600 dark:text-gray-400">
      The page you are looking for does not exist or has been moved. Try one of these popular resources:
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="px-6 py-3 bg-teal-600 hover:bg-teal-700 text-white font-semibold rounded-lg transition-colors">
        Go Home
      </a>
      <a href="/uae/guide/" class="px-6 py-3 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-white font-semibold rounded-lg transition-colors">
        UAE Guide
      </a>
      <a href="/guides/" class="px-6 py-3 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-white font-semibold rounded-lg transition-colors">
        All Guides
      </a>
    </div>
  </div>
</Layout>

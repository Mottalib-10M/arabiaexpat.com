        <option value="35">UK (~35% effective)</option>
        <option value="42">Germany (~42% effective)</option>
        <option value="45">France (~45% effective)</option>
        <option value="30">USA (~30% effective)</option>
        <option value="25">India (~25% effective)</option>
        <option value="20">Philippines (~20% effective)</option>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" for="tax-gulf">Gulf Country</label>
      <select id="tax-gulf" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded px-3 py-1.5 bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        <option value="5">UAE (5% VAT)</option>
        <option value="0">Qatar (0% VAT)</option>
        <option value="15">Saudi Arabia (15% VAT)</option>
        <option value="5">Bahrain (5% VAT)</option>
        <option value="5">Oman (5% VAT)</option>
      </select>
    </div>
  </div>
  <button type="button" onclick="calcTax()" class="text-sm font-semibold bg-teal-600 text-white rounded px-4 py-1.5 hover:bg-teal-700 transition-colors">Calculate Savings</button>
  <div id="tax-result" class="mt-4 hidden">
    <div class="grid grid-cols-3 gap-3 text-center text-sm">
      <div class="bg-white dark:bg-gray-800 rounded p-3 border border-gray-200 dark:border-gray-700">
        <div class="text-xs text-gray-500 dark:text-gray-400">Home Country Net</div>
        <div class="font-bold text-gray-600 dark:text-gray-300" id="tax-home"></div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded p-3 border border-gray-200 dark:border-gray-700">
        <div class="text-xs text-gray-500 dark:text-gray-400">Gulf Net</div>
        <div class="font-bold text-teal-700 dark:text-teal-400" id="tax-gulf-net"></div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded p-3 border border-gray-200 dark:border-gray-700">
        <div class="text-xs text-gray-500 dark:text-gray-400">Annual Gain</div>

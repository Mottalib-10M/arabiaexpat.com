        <tr><td class="px-4 py-2.5 font-medium">Annual Insurance (employer)</td><td class="px-4 py-2.5 text-center">AED 600-12,000</td><td class="px-4 py-2.5 text-center">QAR 3,000-10,000</td><td class="px-4 py-2.5 text-center">SAR 2,500-10,000</td></tr>

<GuideLayout
  title="UAE Gratuity Calculator 2026: End-of-Service Payout"
  description="Calculate your UAE end-of-service gratuity based on basic salary and years worked. Covers the 2021 labor law formula, resignation rules and savings scheme."
  canonical="/uae/gratuity-calculator/"
  schemas={[buildBreadcrumbs(breadcrumbs), buildFAQSchema(faqs), buildArticleSchema("UAE Gratuity Calculator 2026: End-of-Service Benefits", "Calculate UAE gratuity payments.", "https://arabiaexpat.com/uae/gratuity-calculator/", "2025-06-01", "2026-07-01")]}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "UAE", url: "/uae/guide/" }, { name: "Gratuity Calculator", url: "/uae/gratuity-calculator/" }]}

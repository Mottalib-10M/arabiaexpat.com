import GuideLayout from "../../layouts/GuideLayout.astro";
import { buildBreadcrumbs, buildArticleSchema, buildFAQSchema } from "../../lib/seo";
import FAQAccordion from "../../components/ui/FAQAccordion.astro";
import RelatedLinks from "../../components/ui/RelatedLinks.astro";
import SourcesBlock from "../../components/ui/SourcesBlock.astro";

const faqs = [
  { question: "What is gratuity in the UAE?", answer: "Gratuity is an end-of-service benefit mandated by UAE labor law. It is a lump-sum payment made by the employer when an employee's contract ends, calculated based on the basic salary and length of service. It applies to all employees who complete at least one year of continuous service." },
  { question: "How is UAE gratuity calculated?", answer: "For the first five years: 21 calendar days of basic salary per year. After five years: 30 calendar days per year. The total is capped at two years of basic salary. Only the basic salary component is used, not allowances or total package." },
  { question: "Do I get gratuity if I resign?", answer: "Yes. Under the 2021 labor law (Federal Decree-Law No. 33), employees who resign are entitled to the full gratuity amount after completing one year of service. The previous reduction for resignation during the first five years has been eliminated for contracts under the new law." },
  { question: "When is gratuity paid after leaving?", answer: "Employers must pay gratuity within 14 days of the employment end date. If the employer fails to pay within this period, the employee can file a complaint with MoHRE. Unpaid gratuity claims are one of the most common labor disputes resolved by MoHRE." },
  { question: "Is gratuity taxed in the UAE?", answer: "No. Gratuity is entirely tax-free in the UAE, just like regular salary. There are no deductions of any kind from the gratuity payment. The full calculated amount is paid to the employee." },
  { question: "What about the new savings scheme?", answer: "The UAE introduced an optional Alternative End-of-Service Benefits Scheme in 2023, allowing employers to invest gratuity contributions into approved investment funds managed by licensed providers. Employees enrolled in this scheme may earn investment returns above the statutory minimum. Participation is voluntary and agreed upon between employer and employee." },
];

const breadcrumbs = [
  { name: "Home", url: "https://arabiaexpat.com/" },
  { name: "UAE", url: "https://arabiaexpat.com/uae/guide/" },
  { name: "Gratuity Calculator", url: "https://arabiaexpat.com/uae/gratuity-calculator/" },
];

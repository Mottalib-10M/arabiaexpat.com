<script is:inline>
function calcCOL(){
  const r=parseFloat(document.getElementById('col-rent').value)||0;
  const f=parseFloat(document.getElementById('col-food').value)||0;
  const t=parseFloat(document.getElementById('col-transport').value)||0;

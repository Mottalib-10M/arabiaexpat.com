function _calcMethodology(){var c=document.getElementById('dfCat').value,data={visa:{last:'June 2026',cycle:'Within 2 weeks of any regulatory change',source:'MoHRE, MHRSD, MADLSA, ICP, MOI'},salary:{last:'May 2026',cycle:'Semi-annual (aligned with recruitment survey cycles)',source:'Bayt.com, GulfTalent, Robert Half, Hays, Michael Page'},rent:{last:'June 2026',cycle:'Quarterly',source:'Property Finder, Bayut, Qatar Living, DLD Rental Index'},school:{last:'April 2026',cycle:'Annual (aligned with academic year)',source:'KHDA, ADEK, school fee publications'},utilities:{last:'January 2026',cycle:'Annual (aligned with tariff updates)',source:'DEWA, ADDC, Kahramaa, SEC published tariffs'},labor:{last:'June 2026',cycle:'Within 2 weeks of legislative amendments',source:'Federal Decree-Law 33/2021, Saudi Labour Law M/51, Qatar Law 14/2004'},calculator:{last:'June 2026',cycle:'Immediately upon statutory formula changes',source:'Exact statutory formulas from country labor laws'}};var d=data[c];document.getElementById('dfResult').innerHTML='<strong>Last verified: '+d.last+'</strong><br><span class=\'text-xs text-gray-500\'>Update cycle: '+d.cycle+'<br>Primary source: '+d.source+'</span>';}
</script>
</GuideLayout>
